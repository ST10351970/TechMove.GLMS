@{
    ViewData["Title"] = "Add Contract";
}

<h1>Add Contract</h1>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label class="form-label">Client</label>
        <select name="clientId" asp-items="@(ViewBag.Clients as SelectList)" class="form-select" required></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Service level</label>
        <select id="serviceLevel" name="serviceLevel" asp-items="@(ViewBag.ServiceLevels as SelectList)" class="form-select" required></select>
        <small class="form-text text-muted">
            Contract duration is set automatically: Basic = 6 months, Premium = 12 months, Enterprise = 24 months.
        </small>
    </div>

    <div class="mb-3">
        <label class="form-label">Start date</label>
        <input type="date" id="startDate" name="startDate" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">End date (auto-calculated)</label>
        <input type="text" id="endDatePreview" class="form-control" readonly placeholder="Pick a start date and service level" />
        <small class="form-text text-muted">
            Calculated from your start date plus the duration determined by the service level.
        </small>
    </div>

    <div class="mb-3">
        <label class="form-label">Signed agreement (PDF only, max 10 MB)</label>
        <input type="file" name="signedAgreement" accept="application/pdf,.pdf" class="form-control" required />
        <small class="form-text text-muted">Only PDF files are accepted.</small>
    </div>

    <button type="submit" class="btn btn-primary">Create contract</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // client-side PDF guard — paired with server-side FileService rules.
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.querySelector('input[name="signedAgreement"]');
            if (!fileInput) return;
            fileInput.addEventListener('change', function () {
                const file = fileInput.files && fileInput.files[0];
                if (!file) return;
                const okExt = /\.pdf$/i.test(file.name);
                const okSize = file.size <= 10 * 1024 * 1024;
                if (!okExt) {
                    alert('Only PDF files are allowed.');
                    fileInput.value = '';
                    return;
                }
                if (!okSize) {
                    alert('File exceeds 10 MB limit.');
                    fileInput.value = '';
                }
            });
        });

        // End date preview for user feedback.
        (function () {
            const startInput = document.getElementById('startDate');
            const serviceLevelSelect = document.getElementById('serviceLevel');
            const endPreview = document.getElementById('endDatePreview');
            if (!startInput || !serviceLevelSelect || !endPreview) return;

            const durationsByLevel = {
                'Basic': 6,
                'Premium': 12,
                'Enterprise': 24
            };

            function recalcEnd() {
                const start = startInput.value;
                const level = serviceLevelSelect.value;
                if (!start || !level || !(level in durationsByLevel)) {
                    endPreview.value = '';
                    return;
                }
                const startDate = new Date(start + 'T00:00:00');
                if (isNaN(startDate.getTime())) {
                    endPreview.value = '';
                    return;
                }
                const months = durationsByLevel[level];
                const endDate = new Date(startDate);
                endDate.setMonth(endDate.getMonth() + months);

                const yyyy = endDate.getFullYear();
                const mm = String(endDate.getMonth() + 1).padStart(2, '0');
                const dd = String(endDate.getDate()).padStart(2, '0');
                endPreview.value = `${yyyy}-${mm}-${dd}`;
            }

            startInput.addEventListener('change', recalcEnd);
            serviceLevelSelect.addEventListener('change', recalcEnd);
        })();
    </script>
}